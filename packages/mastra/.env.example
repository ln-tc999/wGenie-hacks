# =============================================================================
# LLM provider — at least one required depending on MODEL setting
# =============================================================================
OPENROUTER_API_KEY=sk-or-v1-...
OPENAI_API_KEY=sk-proj-...

# =============================================================================
# Model — provider/model string (optional, defaults to openrouter/anthropic/claude-haiku-4.5)
# =============================================================================
# MODEL=openrouter/anthropic/claude-haiku-4.5
# MODEL=openai/gpt-5.4-mini

# =============================================================================
# Database — Ponder Supabase PostgreSQL (read-only access to indexed data)
# =============================================================================
# --- Local (run `pnpm db:start` first) ---
PONDER_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54342/postgres
# --- Remote (uncomment to use, comment out local above) ---
# PONDER_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# =============================================================================
# Storage — Turso remote LibSQL (required for Vercel, optional for local dev)
# =============================================================================
# Falls back to file:./mastra.db when not set
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

# =============================================================================
# RPC — blockchain data (optional, used by Plasma Vault Agent)
# =============================================================================
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-key
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your-key
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/your-key

# =============================================================================
# Tenderly — Virtual TestNet Admin RPC URLs (required for fork simulation)
# =============================================================================
# Pre-created long-lived Virtual TestNets, one per chain.
# Must be Admin RPC URLs (not Public RPC) for impersonation + state overrides.
TENDERLY_RPC_URL_ETHEREUM=https://virtual.mainnet.rpc.tenderly.co/your-key
TENDERLY_RPC_URL_BASE=https://virtual.base.rpc.tenderly.co/your-key
TENDERLY_RPC_URL_ARBITRUM=https://virtual.arbitrum.rpc.tenderly.co/your-key

# =============================================================================
# API Key — required for protecting the Mastra API from unauthorized access
# =============================================================================
# Generate with: openssl rand -hex 32
MASTRA_API_KEY=your-secret-api-key-here
