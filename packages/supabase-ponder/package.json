  },
  "dependencies": {
    "@supabase/supabase-js": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "dotenv": "^17.2.3",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
