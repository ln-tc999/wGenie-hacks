{
  "name": "@wgenie/fusion-supabase-ponder",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "description": "Supabase client for Ponder indexed blockchain data",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "tsx src/test-connection.ts",
