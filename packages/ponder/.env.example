# =============================================================================
# Database — Supabase PostgreSQL (direct connection for indexing)
# =============================================================================
# --- Local (run `pnpm db:start` first) ---
PONDER_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54342/postgres
# --- Remote (uncomment to use, comment out local above) ---
# PONDER_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# =============================================================================
# RPC — blockchain data sources
# =============================================================================
PONDER_RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/your-key
PONDER_RPC_URL_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/your-key
PONDER_RPC_URL_BASE=https://base-mainnet.g.alchemy.com/v2/your-key
PONDER_RPC_URL_UNICHAIN=https://unichain-mainnet.g.alchemy.com/v2/your-key
PONDER_RPC_URL_AVALANCHE=https://avax-mainnet.g.alchemy.com/v2/your-key
PONDER_RPC_URL_PLASMA=https://plasma-mainnet.g.alchemy.com/v2/your-key
