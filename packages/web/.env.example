NEXT_PUBLIC_RPC_URL_MANTLE_SEPOLIA=https://rpc.sepolia.mantle.xyz

# =============================================================================
# Mastra — Agent server (for AI chat proxy)
# =============================================================================
# --- Local ---
MASTRA_SERVER_URL=http://localhost:4111
# --- Remote (uncomment to use, comment out local above) ---
# MASTRA_SERVER_URL=https://your-mastra-project.vercel.app

# =============================================================================
# Telegram — Bot integration for treasury notifications
# =============================================================================
# Get from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=your-bot-token-here

# =============================================================================
# Tool Executor (Railway backend)
# =============================================================================
# Set to your Railway backend URL (e.g., https://tool-executor.up.railway.app)
# If empty/unset, defaults to local spawnSync execution
NEXT_PUBLIC_CFO_TOOL_EXECUTOR_URL=
