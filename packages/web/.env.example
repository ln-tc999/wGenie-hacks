# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...

# =============================================================================
# RPC — server-side (used in Route Handlers, falls back to NEXT_PUBLIC_* below)
# =============================================================================
RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/your-key
RPC_URL_BASE=https://base-mainnet.g.alchemy.com/v2/your-key
RPC_URL_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/your-key
RPC_URL_UNICHAIN=https://unichain-mainnet.g.alchemy.com/v2/your-key
RPC_URL_AVALANCHE=https://avalanche-mainnet.g.alchemy.com/v2/your-key
RPC_URL_PLASMA=https://plasma-mainnet.g.alchemy.com/v2/your-key

# =============================================================================
# RPC — client-side (used in wagmi provider and as server-side fallback)
# =============================================================================
NEXT_PUBLIC_RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/your-key
NEXT_PUBLIC_RPC_URL_BASE=https://base-mainnet.g.alchemy.com/v2/your-key
NEXT_PUBLIC_RPC_URL_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/your-key
NEXT_PUBLIC_RPC_URL_UNICHAIN=https://unichain-mainnet.g.alchemy.com/v2/your-key
NEXT_PUBLIC_RPC_URL_AVALANCHE=https://avalanche-mainnet.g.alchemy.com/v2/your-key
NEXT_PUBLIC_RPC_URL_PLASMA=https://plasma-mainnet.g.alchemy.com/v2/your-key

# =============================================================================
# YO Protocol — Partner attribution (get yours at https://docs.yo.xyz/integrations/build-with-yo)
# =============================================================================
NEXT_PUBLIC_YO_PARTNER_ID=9999

# =============================================================================
# Mastra — Agent server (for AI chat proxy)
