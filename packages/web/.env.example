# =============================================================================
# RPC — server-side (used in Route Handlers, falls back to NEXT_PUBLIC_* below)
# =============================================================================
RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/your-key
RPC_URL_BASE=https://base-mainnet.g.alchemy.com/v2/your-key
